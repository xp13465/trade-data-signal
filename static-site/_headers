# HTML 入口与内联回测页：每次验证，确保拿到最新版本号 / 内容
/index.html
  Cache-Control: no-cache, must-revalidate

/trade_sim_*
  Cache-Control: no-cache, must-revalidate

# 数据 JSON：每日更新，每次验证
/data/*
  Cache-Control: no-cache, must-revalidate

# 带版本号的静态资源：长缓存 immutable（改动后靠 ?v= 换 URL 破缓存）
/style.css
  Cache-Control: public, max-age=31536000, immutable

/app.js
  Cache-Control: public, max-age=31536000, immutable

/lab.js
  Cache-Control: public, max-age=31536000, immutable

/lab.css
  Cache-Control: public, max-age=31536000, immutable

/vendor/echarts.min.js
  Cache-Control: public, max-age=31536000, immutable
