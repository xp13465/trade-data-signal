<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>Label</key>
	<string>com.trade.etf-national-team</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/linhuichen/code/trade/.venv/bin/python</string>
		<string>-m</string>
		<string>app.collector.etf_national_team</string>
		<string>daily</string>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<!-- 每日 20:07(主槽) + 21:30(兜底二次槽) 跑：SSE/SZSE ETF 每日份额为 T+1 发布，实测 22:06 仍无当日数据（源端常深夜或次日才出）。
	     20:07 错开 backfill-evening 的 20:00 槽。采集器内置 6 天回填窗口，当日份额滞后时靠次日跑补上。
	     21:30 二次槽：应对 20:07 网络抖动/服务器异常，当日兜底幂等覆盖重采。 -->
	<key>StartCalendarInterval</key>
	<array>
		<dict>
			<key>Hour</key>
			<integer>20</integer>
			<key>Minute</key>
			<integer>7</integer>
		</dict>
		<dict>
			<key>Hour</key>
			<integer>21</integer>
			<key>Minute</key>
			<integer>30</integer>
		</dict>
	</array>
	<key>StandardErrorPath</key>
	<string>/Users/linhuichen/code/trade/data/logs/etf_national_team_launchd.err</string>
	<key>StandardOutPath</key>
	<string>/Users/linhuichen/code/trade/data/logs/etf_national_team_launchd.log</string>
	<key>WorkingDirectory</key>
	<string>/Users/linhuichen/code/trade</string>
	<!-- 超时 1800s：ETF 份额采集轻量，给 launchd 合理上限。 -->
	<key>ExitTimeOut</key>
	<integer>1800</integer>
</dict>
</plist>
